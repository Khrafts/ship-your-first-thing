# Postgres connection string. On Railway this is provided by the Postgres
# service (reference it as ${{Postgres.DATABASE_URL}}). When unset, the app
# falls back to an embedded PGlite database at PGLITE_DATA_DIR — used for
# local development and the Playwright e2e suite.
DATABASE_URL=

# Directory for the embedded PGlite database when DATABASE_URL is unset.
PGLITE_DATA_DIR=.data/pglite

# Auth.js session signing secret. Generate one with: openssl rand -base64 32
AUTH_SECRET=

# Required behind a reverse proxy (Railway) so Auth.js trusts the host header.
AUTH_TRUST_HOST=true

# Absolute origin used to build links inside emails (e.g. the confirmation
# link). REQUIRED IN PRODUCTION: links must use a trusted origin, not the
# request Host header (which is forgeable → verification-link poisoning). In
# production the app fails closed if neither APP_URL nor AUTH_URL is set. In
# local dev it falls back to the request host. e.g. https://shipyourfirstthing.com
APP_URL=

# --- Google OAuth (Sign in with Google) ---
# Create an OAuth 2.0 Client (type: Web application) in Google Cloud Console.
# Authorized redirect URIs:
#   https://shipyourfirstthing.com/api/auth/callback/google
#   http://localhost:3000/api/auth/callback/google
# Auth.js reads these env names automatically. When unset, the Google provider
# is simply not registered (email/password still works).
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- Outgoing email (account-confirmation messages) ---
# Transport is chosen by priority: BREVO_API_KEY (HTTPS API) > SMTP_HOST (SMTP) >
# in-memory outbox (when neither is set — used by local dev and the e2e suite, so
# leave both blank to develop the flow with no provider and no real delivery).
#
# PRODUCTION ON RAILWAY: use the Brevo HTTPS API, not SMTP. Railway disables
# outbound SMTP (ports 25/465/587) on Free/Trial/Hobby plans, so an SMTP send
# hangs and times out (ETIMEDOUT). The HTTPS API uses port 443 and is never
# blocked. Generate the key under Brevo → SMTP & API → API Keys (an "xkeysib-…"
# value — this is DISTINCT from the "xsmtpsib-…" SMTP key below).
BREVO_API_KEY=
# Optional override of the Brevo transactional endpoint (default shown).
# BREVO_API_URL=https://api.brevo.com/v3/smtp/email

# SMTP fallback — works for self-hosting, other providers, or Railway Pro (where
# outbound SMTP is enabled; redeploy after upgrading). Ignored when BREVO_API_KEY
# is set. Defaults below are for Brevo's relay.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
# Brevo: SMTP_USER is your Brevo account login email; SMTP_PASSWORD is an SMTP
# key generated under Brevo → SMTP & API → SMTP (NOT your account password).
SMTP_USER=
SMTP_PASSWORD=
# From address; must be a verified sender / authenticated domain in your
# provider, or confirmation mail lands in spam. Used by both transports.
EMAIL_FROM="Ship Your First Thing <no-reply@shipyourfirstthing.com>"

# --- Lesson chat (per-lesson AI tutor) ---
# The chat picks a provider by priority from whichever keys are set:
#   gemini > groq > openrouter, then a deterministic mock if none are set.
# Lower-priority providers with keys become automatic FALLBACKS: if the primary
# fails before streaming any text (e.g. a 429 rate limit), the next one answers.
# With no keys at all, chat uses the offline mock so local dev and the e2e suite
# need no key and spend no tokens.
#
# PRIMARY — Google Gemini (https://aistudio.google.com/apikey). Free tier is the
# most generous fit here: ~1,500 requests/day, 1M-token context (fits the whole
# lesson), no credit card. Default model gemini-2.5-flash.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
#
# FALLBACK — Groq (https://console.groq.com/keys). Free tier ~1,000 req/day per
# model, 30 req/min, very fast, no credit card. Default llama-3.3-70b-versatile.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
#
# OPTIONAL — OpenRouter. NOTE: all ":free" models share ONE per-account quota
# (20 req/min; 50 req/day under $10 of lifetime credits, 1000/day after). A model
# swap does not raise that cap. Confirm model ids at https://openrouter.ai/models.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
# Force a single backend: "gemini" | "groq" | "openrouter" | "mock".
# Default: highest-priority provider with a key (no value needed normally).
CHAT_BACKEND=
# Optional OpenRouter endpoint + attribution overrides (REFERER falls back to APP_URL).
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_REFERER=
# Per-user rate limits (the free tier is small — keep these modest).
CHAT_RATE_PER_MIN=10
CHAT_RATE_PER_DAY=40
